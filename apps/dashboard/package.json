{
  "name": "@felio/app",
  "version": "1.2.0",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "cp .env.local .env && nuxt dev",
    "generate:all": "yarn generate:dev && yarn generate:live",
    "generate:dev": "yarn clean:build && cp .env.dev .env && nuxt generate && yarn clean:folder && yarn deploy && yarn commit && yarn push:dev",
    "generate:live": "yarn clean:build && cp .env.live .env && nuxt generate && yarn clean:folder && yarn deploy",
    "generate:live1": "yarn clean:build && cp .env.live .env && nuxt generate && yarn clean:folder && yarn deploy && yarn commit && yarn push:live",
    "clean:build": "rm -R dist .output",
    "clean:folder": "rm -R ../../../felio-deploy/app/*",
    "deploy": "cp -R ./.output/public/* ../../../felio-deploy/app/",
    "commit": "cd ../../../felio-deploy && git add . && git commit -m \"deploy dashboard\"",
    "push:dev": "cd ../../../felio-deploy && git push origin staging",
    "push:live": "cd ../../../felio-deploy && git push origin main",
    "clean:project": "rm -rf node_modules dist .output .nuxt",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint --ext \".js,.vue\" --ignore-path .gitignore .",
    "lint:fix": "eslint --fix --ext \".js,.vue\" --ignore-path .gitignore .",
    "format": "prettier --write \"**/*.{js,vue,d.ts}\"",
    "format:check": "prettier --check \"**/*.{js,vue,d.ts}\""
  },
  "dependencies": {
    "@pinia/nuxt": "^0.5.1",
    "@types/moment": "^2.13.0",
    "auth-utils": "^1.0.0",
    "axios": "^1.6.8",
    "chart.js": "3.3.2",
    "libphonenumber-js": "^1.10.60",
    "moment": "^2.30.1",
    "nuxt": "3.9.0",
    "nuxt-auth-utils": "0.5.16",
    "primeflex": "^3.3.1",
    "primeicons": "^7.0.0",
    "primevue": "^3.51.0",
    "universal-social-auth": "^0.2.6",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@nuxtjs/eslint-module": "^4.1.0",
    "@nuxtjs/storybook": "7.0.0",
    "@storybook-vue/nuxt": "0.2.1",
    "@storybook-vue/nuxt-storybook": "^0.0.1-latest.7",
    "@storybook/addon-essentials": "7.6.7",
    "@storybook/addon-interactions": "7.6.7",
    "@storybook/addon-links": "7.6.7",
    "@storybook/blocks": "7.6.7",
    "@storybook/builder-vite": "7.6.7",
    "@storybook/testing-library": "^0.2.0",
    "@storybook/vue3": "7.6.7",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.7",
    "@types/node": "^18.17.5",
    "@types/sanitize-html": "^2.11.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "autoprefixer": "^10.4.18",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-config-standard-with-typescript": "^43.0.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-promise": "^6.1.1",
    "eslint-plugin-vue": "^9.24.0",
    "nuxt-anchorscroll": "^1.0.3",
    "nuxt-primevue": "^0.3.1",
    "prettier": "^3.2.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sanitize-html": "^2.13.0",
    "sass": "^1.75.0",
    "sass-loader": "^14.2.0",
    "storybook": "7.6.7",
    "stylelint": "^16.2.1",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.4.3"
  }
}
