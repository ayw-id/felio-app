{
  "name": "@felio/landing",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "build": "nuxt build",
    "dev": "cp .env.dev .env && nuxt dev",
    "generate:dev": "cp .env.dev .env && nuxt generate && yarn deploy && yarn commit && yarn push:dev",
    "generate:live": "cp .env.live .env && nuxt generate && yarn deploy && yarn commit && yarn push:live",
    "deploy": "cp -R ./.output/public/* ../../../felio-deploy/",
    "commit": "cd ../../../felio-deploy && git add . && git commit -m \"deploy landing page\"",
    "push:dev": "cd ../../../felio-deploy && git push origin staging",
    "push:live": "cd ../../../felio-deploy && git push origin main",
    "clean:project": "rm -rf node_modules dist .output .nuxt",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint:js": "eslint --ext \".ts,.vue\" --ignore-path .gitignore .",
    "lint:prettier": "prettier --check .",
    "lint": "yarn lint:js && yarn lint:prettier",
    "lintfix": "prettier --write --list-different . && yarn lint:js --fix",
    "storybook": "storybook dev --port 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@nuxtjs/i18n": "^8.3.1",
    "aos": "3.0.0-beta.6",
    "chart.js": "^4.4.2",
    "nuxt": "^3.10.3",
    "vue": "^3.4.21",
    "vue-chartjs": "^5.3.0",
    "vue-router": "^4.3.0",
    "vuex": "^4.0.2"
  },
  "devDependencies": {
    "@nuxtjs/eslint-module": "^4.1.0",
    "@nuxtjs/storybook": "7.0.0",
    "@storybook-vue/nuxt": "0.2.1",
    "@storybook-vue/nuxt-storybook": "^0.0.1-latest.7",
    "@storybook/addon-essentials": "7.6.7",
    "@storybook/addon-interactions": "7.6.7",
    "@storybook/addon-links": "7.6.7",
    "@storybook/blocks": "7.6.7",
    "@storybook/builder-vite": "7.6.7",
    "@storybook/testing-library": "^0.2.0",
    "@storybook/vue3": "7.6.7",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.7",
    "@types/node": "^18.17.5",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "autoprefixer": "^10.4.18",
    "eslint": "^8.0.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-config-standard-with-typescript": "^43.0.1",
    "eslint-plugin-import": "^2.25.2",
    "eslint-plugin-n": "^15.0.0 || ^16.0.0 ",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-promise": "^6.0.0",
    "eslint-plugin-vue": "^9.22.0",
    "nuxt-anchorscroll": "^1.0.3",
    "nuxt-aos": "^1.2.4",
    "nuxt-mdi": "^1.1.6",
    "prettier": "^3.2.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "storybook": "7.6.7",
    "stylelint": "^16.2.1",
    "tailwindcss": "^3.4.1",
    "typescript": "*"
  }
}
