{
  "name": "felio-app",
  "version": "1.0.0",
  "main": "index.js",
  "license": "MIT",
  "private": "true",
  "scripts": {
    "app": "yarn workspace @felio/app",
    "generate:app:dev": "yarn clean:projects && yarn install && yarn app generate:dev",
    "generate:app:live": "yarn clean:projects && yarn install && yarn app generate:live",
    "dashboard": "yarn workspace @felio/dashboard",
    "landing": "yarn workspace @felio/landing",
    "dstore": "yarn workspace @felio/dstore",
    "resto": "yarn workspace @felio/resto",
    "class": "yarn workspace @felio/class",
    "uilib": "yarn workspace @felio/uilib",
    "packages": "yarn workspace @felio/package",
    "api": "yarn workspace @felio-server/api",
    "clean:projects": "rm -rf node_modules && yarn app clean:project && yarn landing clean:project && yarn dstore clean:project && yarn resto clean:project && yarn uilib clean:project && yarn class clean:project",
    "start": "yarn --stream -r run dev",
    "lint:js": "eslint --ext \".ts,.vue\" --ignore-path .gitignore .",
    "lint:prettier": "prettier --check .",
    "lint": "yarn lint:js && yarn lint:prettier",
    "lintfix": "prettier --write --list-different . && yarn lint:js --fix"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "servers/*"
  ],
  "keywords": [],
  "author": "Ainul Yaqin Wahyudin",
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.30",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.0",
    "eslint-config-standard-with-typescript": "^43.0.1",
    "eslint-import-resolver-typescript": "^3.6.1",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-n": "^16.6.2",
    "eslint-plugin-promise": "^6.1.1",
    "eslint-plugin-simple-import-sort": "^12.0.0",
    "eslint-plugin-vue": "^9.24.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.3",
    "typescript-eslint": "^7.4.0"
  },
  "packageManager": "yarn@1.22.19+sha1.4ba7fc5c6e704fce2066ecbfb0b0d8976fe62447"
}
