}

model voucher {
  id           BigInt   @id @default(autoincrement())
  tipe         String   @db.VarChar(50)
  id_seller    BigInt
  id_customer  BigInt
  deskripsi    String   @db.Text
  nominal      Int
  max_used     Int
  used_count   Int      @default(0)
  is_available Int      @default(1)
  date_start   DateTime @db.DateTime(0)
  date_end     DateTime @db.DateTime(0)
  tgl_created  DateTime @db.DateTime(0)
  tgl_modified DateTime @db.DateTime(0)
}

model withdraw_request {
  id        BigInt   @id @default(autoincrement())
  id_seller BigInt
  nominal   Int
  status    String   @db.VarChar(255)
  tgl_add   DateTime @db.DateTime(0)
  tgl_edit  DateTime @db.DateTime(0)
}

