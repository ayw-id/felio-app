generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model agent_level {
  id                Int                @id @default(autoincrement())
  id_agent_merchant Int
  title             String             @db.VarChar(100)
  commission        Float              @default(0)
  status            agent_level_status @default(ACTIVE)
  agent_total       Int                @default(0)
  date_added        DateTime           @db.DateTime(0)
  date_modified     DateTime           @db.DateTime(0)
}

model agent_member {
  id            BigInt              @id @default(autoincrement())
  id_seller     BigInt
  status        agent_member_status
  date_add      DateTime            @db.DateTime(0)
  date_modified DateTime            @db.DateTime(0)
}

model agent_member_merchant {
  id                BigInt                       @id @default(autoincrement())
  id_agent_merchant BigInt
  id_agent_member   BigInt
  id_agent_level    BigInt
  status            agent_member_merchant_status
  date_added        DateTime                     @db.DateTime(0)
  date_modified     DateTime                     @db.DateTime(0)
}

model agent_member_product {
  id                          BigInt   @id @default(autoincrement())
  id_product                  BigInt
  id_agent_product_commission BigInt
  id_agent_member             BigInt
  status                      String   @default("ACTIVE")
  date_added                  DateTime @db.DateTime(0)
  date_modified               DateTime @db.DateTime(0)
}

model agent_merchant {
  id               BigInt   @id @default(autoincrement())
  id_seller        BigInt
  id_package       Int      @db.TinyInt
  id_package_price Int
  merchant_code    String   @db.VarChar(255)
  total_product    Int      @default(0)
  is_active        Int      @default(1) @db.TinyInt
  expired_package  DateTime @db.DateTime(0)
  date_added       DateTime @db.DateTime(0)
  date_modified    DateTime @db.DateTime(0)
}

model agent_package {
  id        Int    @id @default(autoincrement())
  name      String @db.VarChar(50)
  code      String @db.VarChar(100)
  is_active Int    @default(1)
  is_hide   Int    @default(0)
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model agent_package_prices {
  id            BigInt                      @id @default(autoincrement())
  id_package    BigInt
  period        agent_package_prices_period
  real_price    Int
  price         Int
  discount      Int
  is_active     Boolean
  date_added    DateTime                    @db.DateTime(0)
  date_modified DateTime                    @db.DateTime(0)
}

model agent_product_commission {
  id              BigInt                                   @id @default(autoincrement())
  id_product      BigInt
  id_agent_level  BigInt
  commission_type agent_product_commission_commission_type
  commission      Float
  status          agent_product_commission_status          @default(ACTIVE)
  date_added      DateTime                                 @db.DateTime(0)
  date_modified   DateTime                                 @db.DateTime(0)
}

model agent_registration_page {
  id               BigInt                         @id @default(autoincrement())
  id_merchant      BigInt
  id_agent_level   BigInt
  status           agent_registration_page_status
  code             String                         @db.VarChar(255)
  requirements     String                         @db.Text
  registration_fee Int
  has_expired_date Int                            @default(0) @db.TinyInt
  expired_date     DateTime                       @db.Date
  date_added       DateTime                       @db.DateTime(0)
  date_modified    DateTime                       @db.DateTime(0)
}

model agent_registration_page_visit {
  id         BigInt   @id @default(autoincrement())
  id_seller  BigInt   @default(0)
  user_type  String
  count      Int      @default(1)
  date_added DateTime @db.Date
}

model builder_auth_attempts {
  id              BigInt   @id @default(autoincrement())
  id_builder_user BigInt
  attempt_count   Int      @default(1)
  start_attempt   DateTime @default(now()) @db.DateTime(0)
  expired_attempt DateTime @db.DateTime(0)
}

model chat_message {
  id           BigInt   @id @default(autoincrement())
  id_chat_room BigInt
  id_sender    BigInt
  msg          String   @db.Text
  reply_msg    String   @db.Text
