  account_number          String   @db.VarChar(100)
  xendit_payment_request  String   @db.Text
  xendit_payment_response String   @db.Text
  status                  String   @db.VarChar(100)
  tgl_add                 DateTime @db.DateTime(0)
  tgl_edit                DateTime @db.DateTime(0)
  expiration_date         DateTime @db.DateTime(0)
