}

model chat_room {
  id            BigInt         @id @default(autoincrement())
  id_creator    Int
  name          String         @db.VarChar(255)
  type          chat_room_type
  last_message  String         @db.Text
  last_modified DateTime       @db.DateTime(0)
  created_at    DateTime       @db.DateTime(0)
}

model chat_room_member {
  id           BigInt   @id @default(autoincrement())
  id_chat_room BigInt
  id_chat_user BigInt
  is_banned    Int      @default(0) @db.TinyInt
