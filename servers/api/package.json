{
  "name": "@felio-server/api",
  "version": "1.0.0",
  "description": "",
  "main": "./src/server.ts",
  "scripts": {
    "test1": "jest",
    "test": "NODE_OPTIONS=--experimental-vm-modules npx jest",
    "dev": "pnpm build && nodemon dist/server.js",
    "build": "rm -rf dist && tsc -p .",
    "prisma:init": "npx prisma init",
    "prisma:pull": "npx prisma db pull",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate": "pnpm prisma:migrate:diff && pnpm prisma:migrate:resolve  && pnpm prisma:generate",
    "prisma:migrate:diff": "npx prisma migrate diff --from-empty --to-schema-datamodel prisma/schema.prisma --script > prisma/migrations/0_init/migration.sql",
    "prisma:migrate:resolve": "npx prisma migrate resolve --applied 0_init"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.2",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "node-mocks-http": "^1.14.1",
    "nodemon": "^3.1.0",
    "prisma": "^5.12.1",
    "supertest": "^6.3.4",
    "ts-jest": "^29.1.2",
    "typescript": "^5.4.3"
  },
  "dependencies": {
    "@prisma/client": "5.12.1",
    "@types/jsonwebtoken": "^9.0.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "email-validator": "^2.0.4",
    "express": "^4.19.2",
    "express-rate-limit": "^7.2.0",
    "express-session": "^1.18.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "md5": "^2.3.0",
    "moment": "^2.30.1",
    "object-sizeof": "^2.6.4"
  }
}
